{
  "bundles": {
    "Suissetec\\SsoAuthBundle\\SuissetecSsoAuthBundle": ["all"]
  },
  "copy-from-recipe": {
    "config/": "%CONFIG_DIR%/"
  },
  "env": {
    "#1": "You can use either username and password (default), or API bearer token",
    "#2": "",
    "#3": "SUISSETEC_SSO_API_BEARER_TOKEN=\"change-me\"",
    "SUISSETEC_SSO_URL": "https://testapp.suissetec.ch",
    "SUISSETEC_SSO_APP_ID": "change-me",
    "SUISSETEC_SSO_API_USERNAME": "change-me",
    "SUISSETEC_SSO_API_PASSWORD": "change-me"
  },
  "aliases": [
    "suissetec-sso-auth-bundle",
    "sso-auth"
  ],
  "post-install-output": [
    " * Configure IdP credentials environment variables.",
    " * Check bundle configurations at <info>packages/suissetec-sso-auth.yaml</info>",
    " * Configure symfony security:",
    "   1. Add Suissetec\\SsoAuthBundle\\Authenticator\\SsoAuthenticator as custom_authenticator in config/packages/security.yaml",
    "   2. Set entry_point to Suissetec\\SsoAuthBundle\\Authenticator\\SsoAuthenticator",
    " * <fg=blue>Read</> the documentation at <comment>vendor/suissetec/sso-auth-bundle/README.md</>"
  ]
}
